# Agent 本地配置示例
# 复制为 local_config.env 后按云平台实际路径修改。

LEROBOT_PYTHON=""
LEROBOT_WORKDIR=""
LEROBOT_MODEL_ROOT="models"
AGENT_ENV_TEMPLATE_USD="Asset/lab.usd"
AGENT_ASSET_DIR="Asset"
AGENT_WEB_HOST="127.0.0.1"
AGENT_WEB_PORT="7860"

# 腾讯混元生3D（专业版 API，默认输出 USDZ）
TENCENTCLOUD_SECRET_ID=""
TENCENTCLOUD_SECRET_KEY=""
TENCENTCLOUD_REGION="ap-guangzhou"
# 使用临时密钥时填写：
# TENCENTCLOUD_SESSION_TOKEN=""
# HUNYUAN3D_OUTPUT_DIR="Asset/AI3D"

HF_ENDPOINT="https://hf-mirror.com"
HF_HOME="/root/gpufree-data"
# 完全离线训练时启用：
# HF_HUB_OFFLINE=1

# 可选：如果 lerobot-train 不在 LeRobot 环境 bin 目录下，手动指定
# LEROBOT_TRAIN=""
